<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net6.0;netstandard2.0</TargetFrameworks>
    <AssemblyName>RestSharp</AssemblyName>
    <RootNamespace>RestSharp</RootNamespace>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <LangVersion>8.0</LangVersion>
    <PackageId>RestSharp</PackageId>
    <PackageVersion>102.8.0</PackageVersion>
    <Authors>John Sheehan, RestSharp Community</Authors>
    <Description>Simple REST and HTTP API Client for .NET Core</Description>
    <PackageProjectUrl>http://restsharp.org</PackageProjectUrl>
    <PackageLicenseUrl>https://github.com/restsharp/RestSharp/blob/master/LICENSE.txt</PackageLicenseUrl>
    <PackageIconUrl>http://dl.dropbox.com/u/1827/restsharp100.png</PackageIconUrl>
    <PackageTags>REST HTTP API JSON XML</PackageTags>
    <RepositoryUrl>https://github.com/COG-GTM/RestSharp-.NET-2.0-Fork</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net6.0'">
    <PackageReference Include="System.Text.Json" Version="6.0.0" />
  </ItemGroup>

  <ItemGroup>
    <None Include="T4Helper\T4Helper.tt" />
    <None Include="T4Helper\T4Toolbox.tt" />
    <Compile Remove="T4Helper\T4Toolbox.cs" />
  </ItemGroup>
</Project>
