<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net6.0;netstandard2.0</TargetFrameworks>
    <AssemblyName>RestSharp</AssemblyName>
    <RootNamespace>RestSharp</RootNamespace>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <PackageId>RestSharp</PackageId>
    <PackageVersion>102.7</PackageVersion>
    <Authors>John Sheehan, RestSharp Community</Authors>
    <Description>Simple REST and HTTP API Client</Description>
    <PackageProjectUrl>http://restsharp.org</PackageProjectUrl>
    <PackageLicenseUrl>https://github.com/restsharp/RestSharp/blob/master/LICENSE.txt</PackageLicenseUrl>
    <PackageIconUrl>http://dl.dropbox.com/u/1827/restsharp100.png</PackageIconUrl>
    <PackageTags>REST HTTP API JSON XML</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'netstandard2.0'">
    <PackageReference Include="System.ServiceModel.Primitives" Version="4.10.3" />
  </ItemGroup>

  <ItemGroup>
    <Compile Remove="T4Helper/**" />
    <None Include="T4Helper/**" />
  </ItemGroup>

</Project>
